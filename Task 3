import requests
from bs4 import BeautifulSoup
import csv
import json


class BookScraper:
    def __init__(self):
        self.base_url = "https://books.toscrape.com/catalogue/page-{}.html"
        self.books = []

    # Scrape multiple pages
    def scrape_pages(self, total_pages):
        print("Scraping started...\n")

        for page in range(1, total_pages + 1):
            url = self.base_url.format(page)
            print(f"Scraping Page {page}...")

            response = requests.get(url)

            if response.status_code != 200:
                print(f"Failed to load Page {page}")
                continue

            soup = BeautifulSoup(response.text, "html.parser")

            book_list = soup.find_all("article", class_="product_pod")

            for book in book_list:
                title = book.h3.a["title"]
                price = book.find("p", class_="price_color").text
                availability = book.find("p", class_="instock availability").text.strip()

                self.books.append({
                    "Title": title,
                    "Price": price,
                    "Availability": availability
                })

        print("\nScraping completed successfully!")

    # Save to CSV
    def save_csv(self, filename):
        with open(filename, "w", newline="", encoding="utf-8") as file:
            writer = csv.DictWriter(file, fieldnames=["Title", "Price", "Availability"])
            writer.writeheader()
            writer.writerows(self.books)

        print(f"Data saved to {filename}")

    # Save to JSON
    def save_json(self, filename):
        with open(filename, "w", encoding="utf-8") as file:
            json.dump(self.books, file, indent=4)

        print(f"Data saved to {filename}")

    # Display Data
    def display(self):
        print("\nSample Data:\n")
        for book in self.books[:10]:
            print(book)


def main():
    scraper = BookScraper()

    pages = int(input("Enter number of pages to scrape: "))

    scraper.scrape_pages(pages)
    scraper.display()

    scraper.save_csv("books.csv")
    scraper.save_json("books.json")


if __name__ == "__main__":
    main()
