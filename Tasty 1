# Library Management System using Python OOP

class LibraryItem:
    def __init__(self, item_id, title):
        self._item_id = item_id        # Encapsulation
        self._title = title
        self._available = True

    def borrow(self):
        if self._available:
            self._available = False
            print(f'"{self._title}" has been borrowed.')
        else:
            print(f'"{self._title}" is currently unavailable.')

    def return_item(self):
        self._available = True
        print(f'"{self._title}" has been returned.')

    def display(self):
        status = "Available" if self._available else "Borrowed"
        print(f"ID: {self._item_id}, Title: {self._title}, Status: {status}")


# Inheritance
class Book(LibraryItem):
    def __init__(self, item_id, title, author):
        super().__init__(item_id, title)
        self.author = author

    # Polymorphism
    def display(self):
        status = "Available" if self._available else "Borrowed"
        print(f"Book | ID: {self._item_id} | Title: {self._title} | "
              f"Author: {self.author} | Status: {status}")


class Magazine(LibraryItem):
    def __init__(self, item_id, title, issue):
        super().__init__(item_id, title)
        self.issue = issue

    # Polymorphism
    def display(self):
        status = "Available" if self._available else "Borrowed"
        print(f"Magazine | ID: {self._item_id} | Title: {self._title} | "
              f"Issue: {self.issue} | Status: {status}")


class Library:
    def __init__(self):
        self.items = []

    def add_item(self, item):
        self.items.append(item)
        print("Item added successfully!")

    def show_items(self):
        if not self.items:
            print("Library is empty.")
            return

        print("\nLibrary Collection")
        print("-" * 60)
        for item in self.items:
            item.display()

    def borrow_item(self, item_id):
        for item in self.items:
            if item._item_id == item_id:
                item.borrow()
                return
        print("Item not found.")

    def return_item(self, item_id):
        for item in self.items:
            if item._item_id == item_id:
                item.return_item()
                return
        print("Item not found.")


def main():
    library = Library()

    while True:
        print("\n===== Library Management System =====")
        print("1. Add Book")
        print("2. Add Magazine")
        print("3. View Items")
        print("4. Borrow Item")
        print("5. Return Item")
        print("6. Exit")

        choice = input("Enter your choice: ")

        if choice == "1":
            item_id = input("Book ID: ")
            title = input("Book Title: ")
            author = input("Author: ")
            library.add_item(Book(item_id, title, author))

        elif choice == "2":
            item_id = input("Magazine ID: ")
            title = input("Magazine Title: ")
            issue = input("Issue Number: ")
            library.add_item(Magazine(item_id, title, issue))

        elif choice == "3":
            library.show_items()

        elif choice == "4":
            item_id = input("Enter Item ID to borrow: ")
            library.borrow_item(item_id)

        elif choice == "5":
            item_id = input("Enter Item ID to return: ")
            library.return_item(item_id)

        elif choice == "6":
            print("Thank you for using the Library Management System!")
            break

        else:
            print("Invalid choice! Try again.")


if __name__ == "__main__":
    main()
